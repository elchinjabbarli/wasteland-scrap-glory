// Wasteland: Scrap & Glory - Prisma Schema
// Faz 1: Karakter, Inventory, Temel PvP
// Faz 2: Crafting, Upgrade, Karaborsa, Prestige
// Faz 3: Seferler, Başarımlar, Görevler, Liderlik, Hava Olayı
// Faz 4: Klan, Raid, İntikam, Arkadaşlık, Global Boss
// Faz 5: Rozetler, Unvanlar, Haftalık Etkinlikler, Çoklu Dil

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================================
// PLAYER - Oyuncu karakteri (ana kayıt)
// ============================================================
model Player {
  id            String   @id @default(cuid())
  telegramId    String   @unique @map("telegram_id")
  telegramName  String   @map("telegram_name")
  name          String   @unique
  faction       String   // BOZKIR | COL | FAVELA
  level         Int      @default(1)
  xp            Int      @default(0)
  prestige      Int      @default(0)

  // Birincil istatistikler
  str           Int      @default(5)
  agi           Int      @default(5)
  end           Int      @default(5)
  int           Int      @default(5)
  // İkincil istatistikler
  lck           Int      @default(5)
  chr           Int      @default(5)
  statPoints    Int      @default(0) @map("stat_points")

  // Currency
  scrap         Int      @default(100)
  techPart      Int      @default(0) @map("tech_part")
  crystal       Int      @default(0)

  // Malzemeler
  electronic    Int      @default(0)
  crystalDust   Int      @default(0) @map("crystal_dust")

  // Durum
  state         String   @default("IDLE") // IDLE | IN_COMBAT | INJURED | ...
  injuredUntil  DateTime? @map("injured_until")

  // Faz 2: Günlük ödüller
  dailyChestClaimedAt DateTime? @map("daily_chest_claimed_at")
  adWatchCount       Int      @default(0) @map("ad_watch_count")
  adWatchResetAt     DateTime? @map("ad_watch_reset_at")

  // Faz 3: Başarımlar + Anti-cheat
  achievementPoints  Int      @default(0) @map("achievement_points")
  flagCount          Int      @default(0) @map("flag_count")
  bannedUntil        DateTime? @map("banned_until")
  lastFlagAt         DateTime? @map("last_flag_at")
  questsClaimedAt    DateTime? @map("quests_claimed_at") // son günlük görev ödülü

  // Faz 4: Klan + Sosyal
  clanId             String?  @map("clan_id")
  clanJoinedAt       DateTime? @map("clan_joined_at")

  // Faz 5: Rozet/Unvan + Tutorial
  activeTitle        String?  @map("active_title")
  tutorialStep       Int      @default(0) @map("tutorial_step")

  // İstatistikler
  battlesTotal  Int      @default(0) @map("battles_total")
  battlesWon    Int      @default(0) @map("battles_won")
  battlesLost   Int      @default(0) @map("battles_lost")
  kills         Int      @default(0)

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  items         Item[]
  loadout       Loadout?
  combatsAsA    CombatLog[]
  sessions      Session[]
  craftingJobs  CraftingJob[]
  marketListings MarketListing[]
  tradeOffersSent   TradeOffer[] @relation("trade_offers_sent")
  tradeOffersReceived TradeOffer[] @relation("trade_offers_received")
  prestigeLogs  PrestigeLog[]
  expeditions   Expedition[]
  achievements  PlayerAchievement[]
  dailyQuests   DailyQuest[]
  clanMemberships ClanMember[]
  clanMessagesSent ClanMessage[]
  raidContributions RaidContribution[]
  revengeLinksAsVictim RevengeLink[] @relation("revenge_victim")
  revengeLinksAsKiller RevengeLink[] @relation("revenge_killer")
  friendshipsInitiated Friendship[] @relation("friendship_initiator")
  friendshipsReceived Friendship[] @relation("friendship_receiver")
  globalBossContributions GlobalBossContribution[]
  badges              PlayerBadge[]
  titles              PlayerTitle[]

  @@map("players")
}

// ============================================================
// ITEM TEMPLATE - Sabit eşya şablonları (seed data)
// ============================================================
model ItemTemplate {
  id              String   @id @default(cuid())
  code            String   @unique // "rusty_blade", "leather_vest", ...
  name            String
  slot            String   // WEAPON | ARMOR | SIDE_TOOL | COMPANION
  element         String   @default("PHYSICAL") // PHYSICAL | FIRE | ICE | POISON
  tier            String   @default("COMMON") // COMMON | RARE | EPIC | LEGENDARY
  description     String   @default("")

  // Temel istatistikler (rastgele range için min/max)
  baseDamageMin   Int      @default(0) @map("base_damage_min")
  baseDamageMax   Int      @default(0) @map("base_damage_max")
  baseArmorMin    Int      @default(0) @map("base_armor_min")
  baseArmorMax    Int      @default(0) @map("base_armor_max")
  baseHpBonusMin  Int      @default(0) @map("base_hp_bonus_min")
  baseHpBonusMax  Int      @default(0) @map("base_hp_bonus_max")
  attackSpeed     Float    @default(1.0) @map("attack_speed") // saniyede saldırı

  // Companion'a özel
  companionHp     Int      @default(0) @map("companion_hp")
  companionDamage Int      @default(0) @map("companion_damage")

  // Special effect (status effect tetikleyici)
  effectType      String?  @map("effect_type") // POISON | BURN | FREEZE | STUN | HASTE | EMPOWER | SHIELD | REGEN
  effectChance    Float    @default(0) @map("effect_chance")
  effectDuration  Int      @default(0) @map("effect_duration")

  icon            String   @default("sword") // lucide ikon adı
  faction         String?  // null = tüm fraksiyonlar, yoksa faction-specific

  createdAt       DateTime @default(now()) @map("created_at")

  items           Item[]

  @@map("item_templates")
}

// ============================================================
// ITEM - Oyuncuya ait konkret eşya (instance)
// ============================================================
model Item {
  id            String   @id @default(cuid())
  templateId    String   @map("template_id")
  template      ItemTemplate @relation(fields: [templateId], references: [id])

  ownerId       String   @map("owner_id")
  owner         Player   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  // Prosedürel üretilen değerler
  name          String   // ön-ek + temel + son-ek
  prefix        String?  // "Paslı", "Lanetli", ...
  suffix        String?  // "+1", "of Fire", ...
  rarity        String   // COMMON | RARE | EPIC | LEGENDARY (template tier override edebilir)
  element       String   // PHYSICAL | FIRE | ICE | POISON

  // Roll edilmiş değerler
  baseDamage    Int      @default(0) @map("base_damage")
  baseArmor     Int      @default(0) @map("base_armor")
  baseHpBonus   Int      @default(0) @map("base_hp_bonus")
  attackSpeed   Float    @default(1.0) @map("attack_speed")
  companionHp   Int      @default(0) @map("companion_hp")
  companionDamage Int    @default(0) @map("companion_damage")

  // Effect
  effectType    String?  @map("effect_type")
  effectChance  Float    @default(0) @map("effect_chance")
  effectDuration Int     @default(0) @map("effect_duration")

  // Meta
  upgradeLevel  Int      @default(0) @map("upgrade_level") // 0-10
  durability    Int      @default(100) // 0-100, 0 = Kırık
  state         String   @default("IN_INVENTORY") // IN_INVENTORY | EQUIPPED | LISTED | LOCKED | BROKEN
  protected     Boolean  @default(false) // Permadeath riskinden korumalı mı

  // Faz 2: Market
  listedPrice   Int?     @map("listed_price") // ilan fiyatı (kayıt için)

  icon          String   @default("sword")

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  loadoutWeapon     Loadout? @relation("LoadoutWeapon")
  loadoutArmor      Loadout? @relation("LoadoutArmor")
  loadoutSideTool   Loadout? @relation("LoadoutSideTool")
  loadoutCompanion  Loadout? @relation("LoadoutCompanion")
  marketListing     MarketListing?
  tradeOfferItems   TradeOfferItem[]

  @@index([ownerId])
  @@index([templateId])
  @@map("items")
}

// ============================================================
// LOADOUT - Oyuncunun kuşandığı 4 slot
// ============================================================
model Loadout {
  id              String   @id @default(cuid())
  playerId        String   @unique @map("player_id")
  player          Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  weaponItemId    String?  @unique @map("weapon_item_id")
  weaponItem      Item?    @relation("LoadoutWeapon", fields: [weaponItemId], references: [id], onDelete: SetNull)

  armorItemId     String?  @unique @map("armor_item_id")
  armorItem       Item?    @relation("LoadoutArmor", fields: [armorItemId], references: [id], onDelete: SetNull)

  sideToolItemId  String?  @unique @map("side_tool_item_id")
  sideToolItem    Item?    @relation("LoadoutSideTool", fields: [sideToolItemId], references: [id], onDelete: SetNull)

  companionItemId String?  @unique @map("companion_item_id")
  companionItem   Item?    @relation("LoadoutCompanion", fields: [companionItemId], references: [id], onDelete: SetNull)

  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("loadouts")
}

// ============================================================
// COMBAT LOG - Savaş kaydı (round-by-round JSON)
// ============================================================
model CombatLog {
  id            String   @id @default(cuid())
  playerAId     String   @map("player_a_id")
  playerA       Player   @relation(fields: [playerAId], references: [id], onDelete: Cascade)

  // Rakip: mock PvE ise gerçek Player kaydı yok, sadece ID string saklanır
  playerBId     String?  @map("player_b_id") // gerçek Player ID (PvP) veya null (PvE mock)
  playerBName   String   @default("Unknown") @map("player_b_name")
  playerBFaction String  @default("BOZKIR") @map("player_b_faction")
  playerBLevel  Int      @default(1) @map("player_b_level")

  isPvP         Boolean  @default(true) @map("is_pvp")
  winnerSide    String   @default("A") // "A" (oyuncu kazandı) | "B" (rakip kazandı)

  // Round-by-round log (JSON string)
  roundsJson    String   @map("rounds_json") // JSON array

  // Ödüller (sadece playerA için, Faz 1'de)
  xpGained      Int      @default(0) @map("xp_gained")
  scrapGained   Int      @default(0) @map("scrap_gained")
  techPartGained Int     @default(0) @map("tech_part_gained")
  itemDroppedId String?  @map("item_dropped_id") // kazanılan eşya
  itemLostId    String?  @map("item_lost_id") // kaybedilen eşya (permadeath)

  durationMs    Int      @default(0) @map("duration_ms")
  totalRounds   Int      @default(0) @map("total_rounds")

  createdAt     DateTime @default(now()) @map("created_at")

  @@index([playerAId])
  @@map("combat_logs")
}

// ============================================================
// SESSION - Mock Telegram auth session
// ============================================================
model Session {
  id            String   @id @default(cuid())
  token         String   @unique
  playerId      String   @map("player_id")
  player        Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  telegramId    String   @map("telegram_id")
  telegramName  String   @map("telegram_name")
  expiresAt     DateTime @map("expires_at")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([token])
  @@index([playerId])
  @@map("sessions")
}

// ============================================================
// FAZ 2: CRAFTING JOB - Üretim işi (gerçek zamanlı süre)
// ============================================================
model CraftingJob {
  id            String   @id @default(cuid())
  playerId      String   @map("player_id")
  player        Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  recipeRarity  String   @map("recipe_rarity") // COMMON | RARE | EPIC | LEGENDARY
  slot          String   @default("WEAPON") // hangi slot için üretim (random veya seçim)

  startedAt     DateTime @map("started_at")
  finishesAt    DateTime @map("finishes_at")
  durationMinutes Int    @map("duration_minutes")

  // Malzeme maliyeti (kayıt için)
  scrapCost     Int      @default(0) @map("scrap_cost")
  electronicCost Int     @default(0) @map("electronic_cost")
  techPartCost  Int      @default(0) @map("tech_part_cost")
  crystalDustCost Int    @default(0) @map("crystal_dust_cost")
  successChance Float    @default(1.0) @map("success_chance")

  status        String   @default("IN_PROGRESS") // IN_PROGRESS | COMPLETED | FAILED | CANCELLED
  resultItemId  String?  @map("result_item_id") // başarıyla üretilen eşya
  completedAt   DateTime? @map("completed_at")

  createdAt     DateTime @default(now()) @map("created_at")

  @@index([playerId])
  @@index([status])
  @@map("crafting_jobs")
}

// ============================================================
// FAZ 2: MARKET LISTING - Karaborsa ilanı
// ============================================================
model MarketListing {
  id            String   @id @default(cuid())
  sellerId      String   @map("seller_id")
  seller        Player   @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  itemId        String   @unique @map("item_id")
  item          Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)

  price         Int      // satış fiyatı
  currency      String   @default("SCRAP") // SCRAP | TECH_PART

  listedAt      DateTime @map("listed_at")
  expiresAt     DateTime @map("expires_at")
  durationHours Int      @default(1) @map("duration_hours")

  status        String   @default("ACTIVE") // ACTIVE | SOLD | CANCELLED | EXPIRED
  buyerId       String?  @map("buyer_id")
  soldAt        DateTime? @map("sold_at")
  soldPrice     Int?     @map("sold_price") // fiyata komisyon dahil öncesi

  createdAt     DateTime @default(now()) @map("created_at")

  @@index([sellerId])
  @@index([status])
  @@index([currency])
  @@map("market_listings")
}

// ============================================================
// FAZ 2: TRADE OFFER - İki oyuncu arası takas teklifi
// ============================================================
model TradeOffer {
  id            String   @id @default(cuid())
  fromPlayerId  String   @map("from_player_id")
  fromPlayer    Player   @relation("trade_offers_sent", fields: [fromPlayerId], references: [id], onDelete: Cascade)
  toPlayerId    String   @map("to_player_id")
  toPlayer      Player   @relation("trade_offers_received", fields: [toPlayerId], references: [id], onDelete: Cascade)

  status        String   @default("PENDING") // PENDING | ACCEPTED | REJECTED | CANCELLED | EXPIRED
  expiresAt     DateTime @map("expires_at")

  items         TradeOfferItem[]

  createdAt     DateTime @default(now()) @map("created_at")
  resolvedAt    DateTime? @map("resolved_at")

  @@index([fromPlayerId])
  @@index([toPlayerId])
  @@index([status])
  @@map("trade_offers")
}

model TradeOfferItem {
  id            String   @id @default(cuid())
  tradeOfferId  String   @map("trade_offer_id")
  tradeOffer    TradeOffer @relation(fields: [tradeOfferId], references: [id], onDelete: Cascade)

  itemId        String   @map("item_id")
  item          Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)

  // Bu item teklif edilen mi (offered) yoksa talep edilen mi (requested)?
  side          String   // OFFERED | REQUESTED

  @@index([tradeOfferId])
  @@index([itemId])
  @@map("trade_offer_items")
}

// ============================================================
// FAZ 2: PRESTIGE LOG - Prestige geçmişi (audit)
// ============================================================
model PrestigeLog {
  id            String   @id @default(cuid())
  playerId      String   @map("player_id")
  player        Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  prestigeLevel Int      @map("prestige_level") // ulaşılan yeni prestige seviyesi
  previousLevel Int      @map("previous_level") // prestige öncesi player level
  itemsLost     Int      @default(0) @map("items_lost") // silinen eşya sayısı
  scrapLost     Int      @default(0) @map("scrap_lost")
  electronicLost Int     @default(0) @map("electronic_lost")

  createdAt     DateTime @default(now()) @map("created_at")

  @@index([playerId])
  @@map("prestige_logs")
}

// ============================================================
// FAZ 3: EXPEDITION - Sefer (gerçek zamanlı süre)
// ============================================================
model Expedition {
  id            String   @id @default(cuid())
  playerId      String   @map("player_id")
  player        Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  zoneType      String   @map("zone_type") // RADIATION_VALLEY | ABANDONED_CITY | MOUNTAIN_BUNKER | NUCLEAR_PLANT
  zoneLevel     Int      @map("zone_level") // bölgenin min level'i
  riskPercent   Int      @map("risk_percent") // %10, %20, %30, %50

  startedAt     DateTime @map("started_at")
  finishesAt    DateTime @map("finishes_at")
  durationMinutes Int    @map("duration_minutes")

  status        String   @default("IN_PROGRESS") // IN_PROGRESS | COMPLETED | FAILED | CANCELLED
  success       Boolean? // null = henüz tamamlanmadı
  resolvedAt    DateTime? @map("resolved_at")

  // Sonuçlar (complete olunca doldurulur)
  scrapReward   Int      @default(0) @map("scrap_reward")
  techPartReward Int     @default(0) @map("tech_part_reward")
  itemDroppedId String?  @map("item_dropped_id")
  injuredUntil  DateTime? @map("injured_until") // başarısızsa 24 saat yaralı

  createdAt     DateTime @default(now()) @map("created_at")

  @@index([playerId])
  @@index([status])
  @@map("expeditions")
}

// ============================================================
// FAZ 3: ACHIEVEMENT - Başarım şablonu (code ile unique)
// ============================================================
model Achievement {
  code          String   @id // "first_blood", "serial_killer", ...
  name          String
  description   String
  category      String   // BATTLE | EXPLORATION | ECONOMY | SOCIAL
  points        Int      @default(10) // 10, 25, 50, 100
  rarity        String   @default("COMMON") // COMMON | RARE | EPIC | LEGENDARY
  condition     String   // JSON: { type: "kills", target: 10 }
  icon          String   @default("Trophy")

  players       PlayerAchievement[]

  @@map("achievements")
}

// ============================================================
// FAZ 3: PLAYER ACHIEVEMENT - Oyuncunun kazandığı başarımlar
// ============================================================
model PlayerAchievement {
  playerId        String   @map("player_id")
  player          Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  achievementCode String   @map("achievement_code")
  achievement     Achievement @relation(fields: [achievementCode], references: [code], onDelete: Cascade)
  unlockedAt      DateTime @default(now()) @map("unlocked_at")

  @@id([playerId, achievementCode])
  @@index([playerId])
  @@map("player_achievements")
}

// ============================================================
// FAZ 3: DAILY QUEST - Günlük görev (gece yarısı yenilenir)
// ============================================================
model DailyQuest {
  id            String   @id @default(cuid())
  playerId      String   @map("player_id")
  player        Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  type          String   // PVP_WINS | EXPEDITION_COMPLETE | MARKET_TRANSACTION
  target        Int      @default(1) // hedef sayı
  progress      Int      @default(0)
  completed     Boolean  @default(false)
  claimedAt     DateTime? @map("claimed_at")

  // Ödül
  rewardScrap   Int      @default(0) @map("reward_scrap")
  rewardXp      Int      @default(0) @map("reward_xp")

  expiresAt     DateTime @map("expires_at") // gece yarısı
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([playerId])
  @@index([expiresAt])
  @@map("daily_quests")
}

// ============================================================
// FAZ 3: WEATHER EVENT - Günlük hava olayı (tek kayıt)
// ============================================================
model WeatherEvent {
  id            String   @id @default(cuid())
  type          String   // ACID_RAIN | RADIATION_STORM | GOLDEN_HOUR
  day           String   @unique // "2026-06-29" formatında, günlük tek
  multiplier    Float    @default(1.0) // ödül çarpanı
  combatMul     Float    @default(1.0) @map("combat_mul") // hasar çarpanı
  dropMul       Float    @default(1.0) @map("drop_mul") // drop şansı çarpanı
  durabilityLossMul Float @default(1.0) @map("durability_loss_mul")
  craftingTimeMul Float  @default(1.0) @map("crafting_time_mul")

  description   String   @default("")
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("weather_events")
}

// ============================================================
// FAZ 4: CLAN - Klan
// ============================================================
model Clan {
  id            String   @id @default(cuid())
  name          String   @unique
  description   String   @default("")
  leaderId      String   @map("leader_id")
  // Not: leader Player ile cascade yok (player silinince klan kalabilir), ama leaderId string tutulur

  level         Int      @default(1)
  treasury      Int      @default(0) // hurda hazne
  treasuryTechPart Int   @default(0) @map("treasury_tech_part")

  // Sembol/rükabe (Faz 5'te kozmetik)
  badge         String   @default("shield")

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  members       ClanMember[]
  messages      ClanMessage[]
  raids         RaidBoss[]

  @@map("clans")
}

model ClanMember {
  id            String   @id @default(cuid())
  clanId        String   @map("clan_id")
  clan          Clan     @relation(fields: [clanId], references: [id], onDelete: Cascade)
  playerId      String   @unique @map("player_id")
  player        Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  role          String   @default("MEMBER") // LEADER | OFFICER | MEMBER
  joinedAt      DateTime @default(now()) @map("joined_at")

  // Katkı (donation toplamı)
  totalDonated  Int      @default(0) @map("total_donated")

  @@index([clanId])
  @@map("clan_members")
}

model ClanMessage {
  id            String   @id @default(cuid())
  clanId        String   @map("clan_id")
  clan          Clan     @relation(fields: [clanId], references: [id], onDelete: Cascade)
  senderId      String   @map("sender_id")
  sender        Player   @relation(fields: [senderId], references: [id], onDelete: Cascade)

  content       String
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([clanId, createdAt])
  @@map("clan_messages")
}

// ============================================================
// FAZ 4: RAID BOSS - Grup Raid
// ============================================================
model RaidBoss {
  id            String   @id @default(cuid())
  clanId        String   @map("clan_id")
  clan          Clan     @relation(fields: [clanId], references: [id], onDelete: Cascade)

  code          String   // "mutant_titan", "radyasyon_demon", ...
  name          String
  maxHp         Int      @map("max_hp")
  currentHp     Int      @map("current_hp")

  startedAt     DateTime @default(now()) @map("started_at")
  expiresAt     DateTime @map("expires_at") // 24 saat
  status        String   @default("ACTIVE") // ACTIVE | DEFEATED | EXPIRED
  resolvedAt    DateTime? @map("resolved_at")

  contributions RaidContribution[]

  @@index([clanId])
  @@index([status])
  @@map("raid_bosses")
}

model RaidContribution {
  id            String   @id @default(cuid())
  raidId        String   @map("raid_id")
  raid          RaidBoss @relation(fields: [raidId], references: [id], onDelete: Cascade)
  playerId      String   @map("player_id")
  player        Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  damage        Int      @default(0)
  attacks       Int      @default(0)
  lastAttackAt  DateTime @default(now()) @map("last_attack_at")

  createdAt     DateTime @default(now()) @map("created_at")

  @@unique([raidId, playerId])
  @@index([raidId, damage])
  @@map("raid_contributions")
}

// ============================================================
// FAZ 4: REVENGE LINK - İntikam bağlantısı
// ============================================================
model RevengeLink {
  id            String   @id @default(cuid())
  victimId      String   @map("victim_id")
  victim        Player   @relation("revenge_victim", fields: [victimId], references: [id], onDelete: Cascade)
  killerId      String   @map("killer_id")
  killer        Player   @relation("revenge_killer", fields: [killerId], references: [id], onDelete: Cascade)

  // Kaybedilen eşya bilgisi (snapshot)
  itemName      String   @map("item_name")
  itemRarity    String   @map("item_rarity")
  itemTemplateCode String? @map("item_template_code")

  // Orijinal item silinmiş olabilir, recreate için şablon bilgisi saklanır
  itemDamage    Int      @default(0) @map("item_damage")
  itemArmor     Int      @default(0) @map("item_armor")
  itemHpBonus   Int      @default(0) @map("item_hp_bonus")
  itemElement   String   @default("PHYSICAL") @map("item_element")
  itemSlot      String   @default("WEAPON") @map("item_slot")
  itemIcon      String   @default("sword") @map("item_icon")

  expiresAt     DateTime @map("expires_at") // 24 saat
  used          Boolean  @default(false)
  usedAt        DateTime? @map("used_at")
  result        String?  // WIN | LOSS | null (henüz kullanılmadı)

  createdAt     DateTime @default(now()) @map("created_at")

  @@index([victimId])
  @@index([killerId])
  @@map("revenge_links")
}

// ============================================================
// FAZ 4: FRIENDSHIP - Arkadaşlık
// ============================================================
model Friendship {
  id            String   @id @default(cuid())
  playerId      String   @map("player_id") // istek gönderen
  player        Player   @relation("friendship_initiator", fields: [playerId], references: [id], onDelete: Cascade)
  friendId      String   @map("friend_id") // istek alan
  friend        Player   @relation("friendship_receiver", fields: [friendId], references: [id], onDelete: Cascade)

  status        String   @default("PENDING") // PENDING | ACCEPTED | REJECTED
  createdAt     DateTime @default(now()) @map("created_at")
  resolvedAt    DateTime? @map("resolved_at")

  // Günlük hediye
  lastGiftFromPlayer DateTime? @map("last_gift_from_player")
  lastGiftFromFriend DateTime? @map("last_gift_from_friend")

  @@unique([playerId, friendId])
  @@index([playerId])
  @@index([friendId])
  @@map("friendships")
}

// ============================================================
// FAZ 4: GLOBAL BOSS - Haftalık global boss
// ============================================================
model GlobalBoss {
  id            String   @id @default(cuid())
  week          String   @unique // "2026-W27" formatında
  code          String
  name          String
  maxHp         Int      @map("max_hp")
  currentHp     Int      @map("current_hp")

  startedAt     DateTime @default(now()) @map("started_at")
  expiresAt     DateTime @map("expires_at") // Pazar gece yarısı
  status        String   @default("ACTIVE") // ACTIVE | DEFEATED | EXPIRED
  resolvedAt    DateTime? @map("resolved_at")

  contributions GlobalBossContribution[]

  @@map("global_bosses")
}

model GlobalBossContribution {
  id            String   @id @default(cuid())
  globalBossId  String   @map("global_boss_id")
  globalBoss    GlobalBoss @relation(fields: [globalBossId], references: [id], onDelete: Cascade)
  playerId      String   @map("player_id")
  player        Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  damage        Int      @default(0)
  attacks       Int      @default(0)

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@unique([globalBossId, playerId])
  @@index([globalBossId, damage])
  @@map("global_boss_contributions")
}

// ============================================================
// FAZ 5: PLAYER BADGE - Kozmetik rozetler
// ============================================================
model PlayerBadge {
  id            String   @id @default(cuid())
  playerId      String   @map("player_id")
  player        Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  badgeCode     String   @map("badge_code") // "first_blood_badge", "prestige_badge", vb.
  unlockedAt    DateTime @default(now()) @map("unlocked_at")

  @@unique([playerId, badgeCode])
  @@index([playerId])
  @@map("player_badges")
}

// ============================================================
// FAZ 5: PLAYER TITLE - Unvanlar
// ============================================================
model PlayerTitle {
  id            String   @id @default(cuid())
  playerId      String   @map("player_id")
  player        Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  titleCode     String   @map("title_code") // "rookie", "veteran", "legend", vb.
  unlockedAt    DateTime @default(now()) @map("unlocked_at")

  @@unique([playerId, titleCode])
  @@index([playerId])
  @@map("player_titles")
}

// ============================================================
// FAZ 5: WEEKLY EVENT - Haftalık etkinlik
// ============================================================
model WeeklyEvent {
  id            String   @id @default(cuid())
  week          String   @unique // "2026-W27"
  type          String   // DOUBLE_XP | BOSS_BOOST | DROP_FESTIVAL | FAST_CRAFT
  name          String
  description   String   @default("")

  xpMul         Float    @default(1.0) @map("xp_mul")
  bossHpMul     Float    @default(1.0) @map("boss_hp_mul")
  bossRewardMul Float    @default(1.0) @map("boss_reward_mul")
  dropMul       Float    @default(1.0) @map("drop_mul")
  craftTimeMul  Float    @default(1.0) @map("craft_time_mul")

  startedAt     DateTime @default(now()) @map("started_at")
  expiresAt     DateTime @map("expires_at") // Pazar gece yarısı

  createdAt     DateTime @default(now()) @map("created_at")

  @@map("weekly_events")
}
